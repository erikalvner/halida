#!/bin/bash
# AppRun - starts Halida AppImage with bundled libs, fontconfig, fonts, etc.

if [ -z "$APPDIR" ]; then
    APPDIR="$(dirname "$(readlink -f "$0")")"
fi

export LD_LIBRARY_PATH="$APPDIR/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export XDG_DATA_DIRS="$APPDIR/usr/share${XDG_DATA_DIRS:+:}$XDG_DATA_DIRS"

# Writable locations outside the read-only AppImage mount
FONTCONF_RUNTIME_DIR="${XDG_CONFIG_HOME:-/tmp}/halida-fontconfig"
FONTCONF_CACHE_DIR="${XDG_CACHE_HOME:-/tmp}/halida-fontconfig-cache"

mkdir -p "$FONTCONF_RUNTIME_DIR"
mkdir -p "$FONTCONF_CACHE_DIR"

# Bundled fonts path inside AppImage
BUNDLED_FONTS_DIR="$APPDIR/usr/share/fonts"

# Write fonts.conf dynamically into writable location
cat > "$FONTCONF_RUNTIME_DIR/fonts.conf" <<EOF
<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
  <dir>$BUNDLED_FONTS_DIR</dir>
  <cachedir>$FONTCONF_CACHE_DIR</cachedir>
</fontconfig>
EOF

export FONTCONFIG_PATH="$FONTCONF_RUNTIME_DIR"

# Build font cache if empty
if [ -z "$(ls -A "$FONTCONF_CACHE_DIR" 2>/dev/null)" ]; then
    fc-cache -f "$BUNDLED_FONTS_DIR" >/dev/null 2>&1
fi

exec "$APPDIR/usr/bin/halida2" "$@"
